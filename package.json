  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "changeset": "changeset",
    "npm_publish": "pnpm release; pnpm release:publish;",
    "release": "changeset version; pnpm i; git add .; git commit -m 'chore: changeset Version Packages';",
    "release:publish": "git push origin main:main --tags; changeset publish;",
    "sync": "node ./scripts/sync.js",
    "build-storybook": "storybook build",
    "ci:docs": "pnpm build-storybook",
    "yalc_publish": "node ./scripts/yalc_publish.js",
    "clean": "rm -rf pnpm-lock.yaml node_modules **/*/node_modules",
    "storybook": "storybook dev -p 6006",
    "icons:build": "pnpm --filter @fe-free/icons build",
    "dev": "pnpm storybook"
  },
  "dependencies": {
    "@ant-design/pro-components": "3.1.6-0",
